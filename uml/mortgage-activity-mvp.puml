@startuml
skinparam defaultFontSize 12
skinparam responseMessageBelowArrow true

|Клиент|
start
:Аутентификация через ЕСИА;
if (Авторизация успешна?) then (нет)
  :403 Forbidden;
  :Отобразить "Ошибка входа";
  end
endif

:Автозаполнение данных;
:Загрузка 2-НДФЛ (POST /documents);

|API|
if (Формат/размер валидны?) then (нет)
  :400 Bad Request;
  ->Клиент;
  |Клиент|
  :Отобразить ошибку;
  end
endif
:200 OK + document_id;
->Клиент;

|Клиент|
:Заполнение анкеты;
:Клиентская валидация;
if (Валидация пройдена?) then (нет)
  :Подсветка ошибок;
  end
endif
:POST /applications;
-> API;

|API|
:Валидация структуры;
if (Валидация успешна?) then (да)
  :Сохранить заявку (статус RECEIVED);
  :Фиксация в БД;
  :Публикация в очередь new-applications;
  :202 Accepted + applicationId;
  --> Клиент;
else if (Ошибка валидации) then (да)
  :400 Bad Request + "Ошибка валидации";
  --> Клиент;
  |Клиент|
  :Отобразить ошибку;
  stop
else (Серверная ошибка)
  :500 Internal Server Error;
  --> Клиент;
  |Клиент|
  :Отобразить "Сервер временно недоступен";
  stop
endif

|Клиент|
:Получение 202, показ "В обработке";

|Клиент|
:Инициализация polling (интервал = 3 сек);
repeat
  |Клиент|
  :GET /applications/{id}/status;
  -> API;
  
  |API|
  :Запросить статус из БД;
  if (Заявка найдена?) then (да)
    --> Клиент: {status}
    |Клиент|
    if (статус APPROVED или REJECTED?) then (да)
      :Показать результат;
      break
    elseif (статус MANUAL_REVIEW?) then (да)
      :Показать "Заявка на ручной проверке";
      :Интервал = 30 сек;
    else (PROCESSING/RECEIVED/BKI_RETRY_NEEDED)
      :Интервал = 3 сек;
    endif
  else (нет)
    --> Клиент: 404 Not Found
    |Клиент|
    :Отобразить "Заявка не найдена";
    stop
  endif
  
  if (500 Internal Server Error?) then (да)
    --> Клиент: 500
    |Клиент|
    :Повтор запроса через текущий интервал;
  endif
  
  :Подождать интервал;
repeat while (Финальный статус не получен и нет 404)

|Фоновые воркеры|
:Вычитка из очереди new-applications;
:Статус -> PROCESSING;
:Запрос в БКИ (таймаут 5 сек);
if (Ответ получен?) then (да)
  :Автоматический скоринг;
  if (Балл >= порог?) then (да)
    :Статус -> APPROVED;
    :Формирование графика;
  else (нет)
    :Статус -> REJECTED;
  endif
else (нет)
  if (Ошибка 4xx?) then (да)
    :Статус -> REJECTED;
  else (нет)
    :Статус -> BKI_RETRY_NEEDED;
    :Публикация в очередь bki-retry-tasks;
    |Менеджер|
    :Получение задачи в дашборде;
    :POST /admin/applications/{id}/retry;
    -> API;
    |API|
    if (Заявка существует и статус = BKI_RETRY_NEEDED?) then (да)
      :200 OK;
      --> Менеджер;
      |Менеджер|
      :Отобразить "Повтор отправлен";
      |Фоновые воркеры|
      :Повторный запрос в БКИ;
      repeat
        if (Ответ получен?) then (да)
          :Скоринг -> APPROVED/REJECTED;
          break
        else (нет)
          :Попытка +1;
        endif
      repeat while (Попытка < 3)
      if (Попытка >= 3) then (да)
        :Статус -> MANUAL_REVIEW;
        |Менеджер|
        :Ручной анализ и решение;
        :Заполнить комментарий;
        :Нажать APPROVED или REJECTED;
        |Фоновые воркеры|
        :Сохранить решение, комментарий, время, ID менеджера;
        :Статус -> APPROVED или REJECTED;
      endif
    else if (Заявка не найдена?) then (да)
      :404 Not Found;
      --> Менеджер;
      |Менеджер|
      :Отобразить "Заявка не найдена";
    else (статус не позволяет повторить)
      :409 Conflict;
      --> Менеджер;
      |Менеджер|
      :Отобразить "Повтор невозможен";
    endif
  endif
endif

:Финальный статус в БД;
|Клиент|
:Отображение в ЛК;
:Просмотр графика (если одобрено);
end
@enduml