@startuml
skinparam defaultFontSize 12
skinparam responseMessageBelowArrow true

|Клиент|
start
:Аутентификация через ЕСИА;
if (Авторизация успешна?) then (нет)
  :403 Forbidden;
  end
endif

:Автозаполнение данных;
:Загрузка 2-НДФЛ (POST /documents);

|API|
if (Формат/размер валидны?) then (нет)
  :400 Bad Request;
  ->Клиент;
  |Клиент|
  :Отобразить ошибку;
  end
endif
:200 OK + document_id;
->Клиент;

|Клиент|
:Заполнение анкеты;
:Клиентская валидация;
if (Валидация пройдена?) then (нет)
  :Подсветка ошибок;
  end
endif
:POST /applications;

|API|
:Валидация структуры;
:Сохранить заявку (статус RECEIVED);
:Фиксация в БД;
:Публикация в очередь new-applications;
:202 Accepted + applicationId;
->Клиент;

|Клиент|
:Получение 202, показ "В обработке";
:Ожидание обновления статуса (Polling);
note right
  GET /status каждые 3 сек.
  APPROVED/REJECTED → выход.
  MANUAL_REVIEW → интервал 30 сек.
  Иначе → 3 сек.
end note

|Фоновые воркеры|
:Вычитка из очереди new-applications;
:Статус -> PROCESSING;
:Запрос в БКИ (таймаут 5 сек);

if (Ответ получен?) then (да)
  :Автоматический скоринг;
  if (Балл >= порог?) then (да)
    :Статус -> APPROVED;
    :Формирование графика;
  else (нет)
    :Статус -> REJECTED;
  endif
else (нет)
  if (Ошибка 4xx?) then (да)
    :Статус -> REJECTED;
  else (нет)
    :Статус -> BKI_RETRY_NEEDED;
    :Публикация в очередь bki-retry-tasks;
    |Менеджер|
    :Дашборд → заявка;
    :POST /admin/applications/{id}/retry-bki;
    |Фоновые воркеры|
    :Повторный запрос в БКИ;
    repeat
      if (Ответ получен?) then (да)
        :Скоринг → APPROVED/REJECTED;
        break
      else (нет)
        :Попытка +1;
      endif
    repeat while (Попытка < 3)
    if (Попытка >= 3) then (да)
      :Статус -> MANUAL_REVIEW;
      |Менеджер|
      :Ручной анализ, комментарий, решение;
      |Фоновые воркеры|
      :APPROVED или REJECTED;
    endif
  endif
endif

:Финальный статус в БД;
|Клиент|
:Отображение в ЛК;
:Просмотр графика (если одобрено);
end
@enduml