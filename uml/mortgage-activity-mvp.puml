@startuml
skinparam defaultFontSize 12
skinparam responseMessageBelowArrow true

|Клиент|
start
:Аутентификация через ЕСИА;
if (Авторизация успешна?) then (нет)
  :403 Forbidden;
  end
endif

:Автозаполнение данных;
:Загрузка 2-НДФЛ (POST /documents);

|API|
if (Формат/размер валидны?) then (нет)
  :400 Bad Request;
  ->Клиент;
  |Клиент|
  :Отобразить ошибку;
  end
endif
:200 OK + document_id;
->Клиент;

|Клиент|
:Заполнение анкеты;
:Клиентская валидация;
if (Валидация пройдена?) then (нет)
  :Подсветка ошибок;
  end
endif
:POST /applications;
-> API;

|API|
:Валидация структуры;
if (Валидация успешна?) then (да)
  :Сохранить заявку (RECEIVED);
  :Фиксация в БД;
  :Публикация в очередь new-applications;
  :202 Accepted;
  --> Клиент;
else (нет)
  :400 Bad Request;
  --> Клиент;
  |Клиент|
  :Отобразить ошибку;
  end
endif

|Клиент|
:Получение 202;
:Начало polling;

repeat
  |Клиент|
  :GET /applications/{id}/status;
  -> API;
  
  |API|
  :Запросить статус из БД;
  --> Клиент: статус;
  
  |Клиент|
  if (статус = APPROVED или REJECTED?) then (да)
    :Показать результат;
    break
  elseif (статус = MANUAL_REVIEW?) then (да)
    :Интервал = 30 сек;
  else
    :Интервал = 3 сек;
  endif
  :Подождать интервал;
repeat while (финальный статус не получен)

|Фоновые воркеры|
:Вычитка из очереди new-applications;
:Статус -> PROCESSING;
:Запрос в БКИ;

if (Ответ получен?) then (да)
  :Автоматический скоринг;
  if (Балл >= порог?) then (да)
    :Статус -> APPROVED;
    :Формирование графика;
  else (нет)
    :Статус -> REJECTED;
  endif
else (нет)
  if (Ошибка 4xx?) then (да)
    :Статус -> REJECTED;
  else (нет)
    :Статус -> BKI_RETRY_NEEDED;
    :Публикация в очередь bki-retry-tasks;
    |Менеджер|
    :Дашборд;
    :POST /admin/applications/{id}/retry;
    |Фоновые воркеры|
    :Повторный запрос в БКИ;
    repeat
      :Попытка +1;
    repeat while (Попытка < 3)
    if (Попытка >= 3) then (да)
      :Статус -> MANUAL_REVIEW;
      |Менеджер|
      :Ручной анализ, комментарий;
      :Решение APPROVED или REJECTED;
    endif
  endif
endif

|Клиент|
:Отображение в ЛК;
:Просмотр графика (если одобрено);
end
@enduml