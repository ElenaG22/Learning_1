@startuml
skinparam defaultFontSize 12
skinparam responseMessageBelowArrow true

|Клиент|
start
:Аутентификация через ЕСИА;
if (Авторизация успешна?) then (нет)
  :403 Forbidden;
  end
endif

:Автозаполнение данных;
:Загрузка 2-НДФЛ (POST /documents);

|API|
if (Формат/размер валидны?) then (нет)
  :400 Bad Request;
  ->Клиент;
  end
endif
:200 OK + document_id;
->Клиент;

|Клиент|
:Заполнение анкеты;
:Клиентская валидация;
if (Валидация пройдена?) then (нет)
  :Подсветка ошибок;
  end
endif
:POST /applications;

|API|
:Валидация структуры;
:Сохранить заявку (статус RECEIVED);
:COMMIT (короткая транзакция);
:Публикация события <<очередь>>;
:202 Accepted + applicationId;
->Клиент;

|Клиент|
:Получение 202, показ "В обработке";
:Ожидание обновления статуса;

|Фоновые воркеры|
:Вычитка из очереди <<очередь>>;
:Статус -> PROCESSING;
:Запрос в БКИ (таймаут 5 сек);
if (Ответ получен?) then (да)
  :Автоматический скоринг;
  if (Балл >= порог?) then (да)
    :Статус -> APPROVED;
    :Формирование графика;
    :Статус -> ISSUED;
  else (нет)
    :Статус -> REJECTED;
  endif
else (нет)
  if (Ошибка 4xx?) then (да)
    :Статус -> REJECTED;
  else (нет)
    :Статус -> BKI_RETRY_NEEDED;
    :Публикация задачи в очередь <<очередь>>;
    |Менеджер|
    :Получение задачи в дашборде;
    :Ручной повтор (кнопка);
    |Фоновые воркеры|
    :Повторный запрос в БКИ;
    repeat
      if (Ответ получен?) then (да)
        :Скоринг -> APPROVED/REJECTED;
        break
      else (нет)
        :Попытка +1;
      endif
    repeat while (Попытка <= 3)
    if (Лимит исчерпан) then (да)
      :Статус -> MANUAL_REVIEW;
      |Менеджер|
      :Ручной анализ и решение;
      |Фоновые воркеры|
      :Обновление статуса по решению;
    endif
  endif
endif

:Публикация изменения статуса <<очередь>>;
|Клиент|
:Получение обновления;
:Отображение в ЛК;
:Просмотр графика (если одобрено);
end
@enduml