@startuml
skinparam defaultFontSize 12

|Заёмщик|
start
floating note right: <b>[152-ФЗ]</b> Все критические действия\n //автоматически// логируются в БД для <color:red>аудита</color>

:Аутентификация через ЕСИА;
if (Авторизация успешна?) then (нет)
  :Доступ запрещён;
  stop
endif

:Автозаполнение данных (ФИО, паспорт, СНИЛС, ИНН);
:Заполнение анкеты (доход, объект, параметры);
:Загрузка справки 2-НДФЛ;
if (2-НДФЛ загружена?) then (нет)
  :Ошибка: обязательный документ отсутствует;
  stop
endif

:Клиентская валидация полей;
if (Валидация пройдена?) then (нет)
  :Ошибка валидации (подсветка полей);
  stop
endif

:Отправка заявки;

|Система|
fork
  :Сохранение заявки в БД;
  :Установка статуса: "На рассмотрении";
fork again
  :Первичный запрос в БКИ (таймаут 5 сек);
  :БКИ_Успех = false;
  if (Ответ получен?) then (да)
    :БКИ_Успех = true;
  else (нет)
    if (Ошибка 4xx?) then (да)
      :БКИ_ТипОшибки = "4xx";
    else (нет)
      :БКИ_ТипОшибки = "5xx/таймаут";
      :Попыток = 0;
      repeat
        |Менеджер|
        :Инициация ручного повтора;
        |Система|
        :Повторный запрос в БКИ;
        if (Ответ получен?) then (да)
          :БКИ_Успех = true;
          break
        else (нет)
          :Попыток = Попыток + 1;
        endif
      repeat while (Попыток <= 3?) is (да) not (нет)
      if (БКИ_Успех == false) then (да)
        :БКИ_ТипОшибки = "лимит_повторов";
      endif
    endif
  endif
end fork

|Система|
' === Автоматическая ветка (успех БКИ) ===
if (БКИ_Успех == true) then (да)
  :Автоматический скоринг (ПДН 50%, КИ 30%, Стаж 20%);
  if (Балл >= Порог?) then (да)
    :Установка статуса: "Одобрена";
    :Формирование аннуитетного графика;
    :Установка статуса: "Выдана";
  else (нет)
    :Установка статуса: "Отказана";
  endif

' === Ручная ветка (ошибки БКИ) ===
else (нет)
  if (БКИ_ТипОшибки == "4xx") then (да)
    :Установка статуса: "Отказана";
  else (нет)
    :Установка статуса: "Ошибка БКИ (в обработке)";
    |Менеджер|
    :Ручной анализ кейса и принятие решения;
    if (Решение: одобрить?) then (да)
      :Установка статуса: "Одобрена";
      :Формирование графика;
      :Установка статуса: "Выдана";
    else (нет)
      :Установка статуса: "Отказана";
    endif
  endif
endif

|Заёмщик|
:Получение уведомления в ЛК;
:Просмотр статуса, графика и остатка долга;
stop
@enduml