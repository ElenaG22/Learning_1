@startuml
skinparam defaultFontSize 12

|Заёмщик|
start

:Аутентификация через ЕСИА;
if (Авторизация успешна?) then (нет)
  :Доступ запрещён;
  end
endif

:Автозаполнение данных;
:Заполнение анкеты;
:POST /documents (2-НДФЛ);

|Система|
:Проверить файл\n(формат, размер ≤10 МБ);

|Заёмщик|
if (2-НДФЛ загружена?) then (нет)
  :Ошибка: документ обязателен;
  end
endif

:Клиентская валидация;
if (Валидация пройдена?) then (нет)
  :Ошибка валидации;
  end
endif

:POST /applications;

|Система|
:Сохранить заявку;
:Статус "На рассмотрении";
:Запрос в БКИ (5 сек);

if (Ответ получен?) then (да)
  :Скоринг;
  if (Балл >= порог?) then (да)
    :Статус "Одобрена";
    :Формирование графика;
    :Статус "Выдана";
  else (нет)
    :Статус "Отказана";
  endif

else (нет)
  if (Ошибка 4xx?) then (да)
    :Статус "Отказана";
  else (нет)
    :Попытка = 1;
    repeat
      |Менеджер|
      :Ручной повтор;
      |Система|
      :Повторный запрос в БКИ;
      if (Ответ получен?) then (да)
        :Скоринг;
        if (Балл >= порог?) then (да)
          :Статус "Одобрена";
          :Формирование графика;
          :Статус "Выдана";
        else (нет)
          :Статус "Отказана";
        endif
        break
      else (нет)
        :Попытка = Попытка + 1;
      endif
    repeat while (Попытка <= 3)
    
    if (Ответ не получен) then (да)
      :Статус "Ошибка БКИ";
      |Менеджер|
      :Ручной анализ;
      if (Одобрить?) then (да)
        |Система|
        :Статус "Одобрена";
        :Формирование графика;
        :Статус "Выдана";
      else (нет)
        :Статус "Отказана";
      endif
    endif
  endif
endif

|Заёмщик|
:Получить уведомление в ЛК;
:Просмотр статуса и графика;
end
@enduml