@startuml
skinparam defaultFontSize 12

|Заёмщик|
start
floating note right: <b>[152-ФЗ]</b> Все критические действия\nавтоматически логируются в БД для аудита

:Аутентификация через ЕСИА;
if (Авторизация успешна?) then (нет)
  :Доступ запрещён;
  stop
endif

:Автозаполнение данных;
:Заполнение анкеты;

|Система|
:Запрос на получение URL для загрузки;
|Заёмщик|
:Прямая загрузка 2-НДФЛ в S3;

if (2-НДФЛ загружена?) then (нет)
  :Ошибка: обязательный документ отсутствует;
  stop
endif

:Клиентская валидация полей;
if (Валидация пройдена?) then (нет)
  :Ошибка валидации;
  stop
endif

:Отправка заявки POST /applications;

|Система|
:Сохранение заявки в БД;
:Установка статуса "На рассмотрении";

:Первичный запрос в БКИ (таймаут 5 сек);

if (Ответ получен?) then (да)
  :Автоматический скоринг;
  if (Балл >= Порог?) then (да)
    :Статус "Одобрена";
    :Формирование аннуитетного графика;
    :Статус "Выдана";
  else (нет)
    :Статус "Отказана";
    stop
  endif
else (нет)
  if (Ошибка 4xx?) then (да)
    :Статус "Отказана";
    stop
  else (нет)
    :Ошибка 5xx или таймаут;
    :Попытка = 1;
    
    repeat
      |Менеджер|
      :Ручной повтор запроса;
      
      |Система|
      :Повторный запрос в БКИ;
      
      if (Ответ получен?) then (да)
        :Автоматический скоринг;
        if (Балл >= Порог?) then (да)
          :Статус "Одобрена";
          :Формирование графика;
          :Статус "Выдана";
        else (нет)
          :Статус "Отказана";
          stop
        endif
        break
      else (нет)
        :Попытка = Попытка + 1;
      endif
    repeat while (Попытка <= 3)
    
    if (Ответ не получен после 3 повторов) then (да)
      :Статус "Ошибка БКИ (в обработке)";
      
      |Менеджер|
      :Ручной анализ кейса;
      
      if (Решение: одобрить?) then (да)
        |Система|
        :Статус "Одобрена";
        :Формирование графика;
        :Статус "Выдана";
      else (нет)
        :Статус "Отказана";
        stop
      endif
    endif
  endif
endif

|Заёмщик|
:Получение уведомления в ЛК;
:Просмотр статуса, графика и остатка долга;
stop
@enduml